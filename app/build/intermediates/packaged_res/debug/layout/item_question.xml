<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Üst satır: Konu + Zorluk + Sil -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvTopic"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="11sp"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:text="Konu" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipDifficulty"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="Orta"
                android:textSize="11sp"
                app:chipMinHeight="28dp"
                android:clickable="false" />

            <ImageView
                android:id="@+id/ivDelete"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_delete"
                android:tint="#CCCCCC"
                android:padding="4dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless" />
        </LinearLayout>

        <!-- Alt konu -->
        <TextView
            android:id="@+id/tvSubtopic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="8dp"
            android:text="Alt konu" />

        <!-- Soru Görseli (varsa) -->
        <ImageView
            android:id="@+id/ivQuestionImage"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:scaleType="fitStart"
            android:adjustViewBounds="true"
            android:visibility="gone"
            android:layout_marginBottom="8dp" />

        <!-- Soru Metni -->
        <TextView
            android:id="@+id/tvQuestionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:lineSpacingMultiplier="1.3"
            android:text="Soru metni..." />

        <!-- Alt satır: Sayfa + Şık sayısı -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <TextView
                android:id="@+id/tvPage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                android:text="S.1" />

            <TextView
                android:id="@+id/tvOptionCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                android:text="4 şık" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
