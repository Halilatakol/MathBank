<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:title="Soru Bankası"
        app:titleTextColor="@color/white" />

    <!-- Tab Layout -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        app:tabTextColor="#99FFFFFF"
        app:tabSelectedTextColor="@color/white"
        app:tabIndicatorColor="@color/accent">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sorular" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Testlerim" />
    </com.google.android.material.tabs.TabLayout>

    <!-- SORULAR CONTAINER -->
    <LinearLayout
        android:id="@+id/questionContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Arama -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            app:boxCornerRadiusTopStart="10dp"
            app:boxCornerRadiusTopEnd="10dp"
            app:boxCornerRadiusBottomStart="10dp"
            app:boxCornerRadiusBottomEnd="10dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="🔍 Soru ara..."
                android:imeOptions="actionSearch" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Zorluk Filtreleri -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <com.google.android.material.chip.ChipGroup
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleLine="true"
                android:layout_marginBottom="4dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipEasy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🟢 Kolay"
                    style="@style/Widget.MaterialComponents.Chip.Filter" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipMedium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🟡 Orta"
                    style="@style/Widget.MaterialComponents.Chip.Filter" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipHard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔴 Zor"
                    style="@style/Widget.MaterialComponents.Chip.Filter" />
            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <!-- Konu Filtreleri -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="4dp">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupTopics"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleLine="true" />
        </HorizontalScrollView>

        <!-- Soru Sayısı & Test Butonu -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/tvQuestionCount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0 soru"
                android:textSize="13sp"
                android:textColor="@color/text_secondary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCreateTest"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="✏️ Test Oluştur"
                android:textSize="12sp"
                app:backgroundTint="@color/accent"
                app:cornerRadius="8dp" />
        </LinearLayout>

        <!-- Sorular Listesi -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvQuestions"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:padding="8dp" />

        <!-- Boş durum -->
        <TextView
            android:id="@+id/emptyViewQuestions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📚\n\nHenüz soru eklenmemiş.\nAna sayfadan PDF ekleyin."
            android:gravity="center"
            android:textSize="16sp"
            android:textColor="@color/text_hint"
            android:padding="48dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- TESTLER CONTAINER -->
    <LinearLayout
        android:id="@+id/testContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvTestCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0 test"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:padding="16dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvTests"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:padding="8dp" />

        <TextView
            android:id="@+id/emptyViewTests"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📋\n\nHenüz test oluşturulmamış.\nAna sayfadan test oluşturun."
            android:gravity="center"
            android:textSize="16sp"
            android:textColor="@color/text_hint"
            android:padding="48dp"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>
