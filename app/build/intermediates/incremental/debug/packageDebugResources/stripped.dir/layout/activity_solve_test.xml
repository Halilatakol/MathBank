<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Üst Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/primary"
        android:padding="12dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvQuestionNumber"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Soru 1 / 20"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/tvAnswered"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0/20 cevaplanmış"
            android:textSize="12sp"
            android:textColor="#BBDEFB"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="40:00"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="#33FFFFFF"
            android:padding="6dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Progress -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progressTest"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        app:trackCornerRadius="0dp"
        app:indicatorColor="@color/accent"
        app:trackColor="@color/surface_variant" />

    <!-- Soru İçeriği (scroll edilebilir) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Konu Chip'i -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tvTopic"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:text="Geometri › Üçgenler" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipDifficulty"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:text="🟡 Orta"
                    android:textSize="11sp"
                    android:clickable="false"
                    app:chipMinHeight="28dp" />
            </LinearLayout>

            <!-- Soru Görseli -->
            <ImageView
                android:id="@+id/ivQuestionImage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:scaleType="fitStart"
                android:visibility="gone"
                android:layout_marginBottom="12dp" />

            <!-- Soru Metni -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvQuestionText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:lineSpacingMultiplier="1.5"
                    android:text="Soru metni burada görünecek." />
            </com.google.android.material.card.MaterialCardView>

            <!-- Şıklar -->
            <RadioGroup
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <RadioButton
                    android:id="@+id/rbA"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="A) ..."
                    android:textSize="15sp"
                    android:padding="12dp"
                    android:layout_marginBottom="8dp"
                    android:button="@null"
                    android:drawableEnd="@null"
                    android:background="@drawable/bg_option"
                    android:visibility="gone" />

                <RadioButton
                    android:id="@+id/rbB"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="B) ..."
                    android:textSize="15sp"
                    android:padding="12dp"
                    android:layout_marginBottom="8dp"
                    android:button="@null"
                    android:background="@drawable/bg_option"
                    android:visibility="gone" />

                <RadioButton
                    android:id="@+id/rbC"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="C) ..."
                    android:textSize="15sp"
                    android:padding="12dp"
                    android:layout_marginBottom="8dp"
                    android:button="@null"
                    android:background="@drawable/bg_option"
                    android:visibility="gone" />

                <RadioButton
                    android:id="@+id/rbD"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="D) ..."
                    android:textSize="15sp"
                    android:padding="12dp"
                    android:layout_marginBottom="8dp"
                    android:button="@null"
                    android:background="@drawable/bg_option"
                    android:visibility="gone" />

                <RadioButton
                    android:id="@+id/rbE"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="E) ..."
                    android:textSize="15sp"
                    android:padding="12dp"
                    android:layout_marginBottom="8dp"
                    android:button="@null"
                    android:background="@drawable/bg_option"
                    android:visibility="gone" />

            </RadioGroup>
        </LinearLayout>
    </ScrollView>

    <!-- Alt Navigasyon -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@color/surface"
        android:elevation="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPrevious"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="‹ Önceki"
            android:textColor="@color/primary"
            app:strokeColor="@color/primary"
            app:cornerRadius="10dp"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNext"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="2"
            android:text="Sonraki ›"
            android:textStyle="bold"
            app:backgroundTint="@color/primary"
            app:cornerRadius="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFinish"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Bitir"
            android:textStyle="bold"
            app:backgroundTint="@color/error"
            app:cornerRadius="10dp"
            android:layout_marginStart="8dp" />
    </LinearLayout>

</LinearLayout>
